# =============================================================================
# API standalone local dev (running `npm start` WITHOUT docker-compose).
# In production, docker-compose.prod.yml injects these vars itself from the
# repo-root .env — this file is NOT read by the compose stack.
# =============================================================================

NODE_ENV=development
PORT=3000

# Ready to use with the repo-root docker-compose.yml dev database (db service).
# Adjust host/port/credentials if you run your own Postgres instance.
DATABASE_URL=postgresql://actify:actify@localhost:5432/actify

# Signs/verifies access tokens (requireAuth middleware). Any random long
# string works in dev; use a real secret in production.
JWT_SECRET=dev-secret-change-me

# XRPL JSON-RPC endpoint used to verify order payments and NFT mints on-chain.
# Defaults to the public Testnet endpoint.
XRPL_RPC_URL=https://s.altnet.rippletest.net:51234/

# On-chain verification polls `tx` until the transaction is validated by
# consensus (wallets return the hash at submission, ~3-5s earlier). Defaults:
# 8 attempts spaced 1500ms apart (~10.5s worst case).
XRPL_TX_POLL_ATTEMPTS=8
XRPL_TX_POLL_INTERVAL_MS=1500

# Bootstrap admin: when this exact XRPL wallet address logs in, its account is
# promoted to the admin role automatically. Leave empty to disable.
ADMIN_WALLET_ADDRESS=
