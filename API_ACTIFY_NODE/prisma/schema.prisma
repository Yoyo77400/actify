generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // pg_trgm backs the GIN trigram indexes on listings.title/description:
  // a B-tree can only serve left-anchored patterns, while the search service
  // matches ILIKE '%q%' (contains). See docs/query-optimization.md.
  extensions = [pg_trgm]
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("roles")
}

model User {
  id          String    @id @default(uuid())
  roleId      Int       @map("role_id")
  username    String?   @unique
  displayName String?   @map("display_name")
  email       String?   @unique
  bio         String?
  avatarCid   String?   @map("avatar_cid")
  isVerified  Boolean   @default(false) @map("is_verified")
  isBanned    Boolean   @default(false) @map("is_banned")
  createdAt   DateTime  @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")

  // 2FA (TOTP). Le secret est écrit à l'enrôlement (/auth/2fa/setup) mais
  // twoFactorEnabled ne passe à true qu'après confirmation d'un premier code
  // (/auth/2fa/confirm) — évite de verrouiller un compte sur un secret jamais
  // synchronisé avec le téléphone.
  twoFactorSecret  String?  @map("two_factor_secret")
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")

  role      Role       @relation(fields: [roleId], references: [id])
  wallets   Wallet[]
  listings  Listing[]
  purchases Purchase[]
  downloads Download[]
  reviews   Review[]
  favorites Favorite[]
  nfts      Nft[]      @relation("NftOwner")
  resales   Resale[]

  @@map("users")
}

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  address   String   @unique
  chain     String
  label     String?
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  // Seller's primary wallet is resolved on every order creation
  // (orders.service.getSellerPrimaryWalletOrThrow) and wallets are listed per
  // user; the unique(address) index cannot serve user_id lookups.
  @@index([userId])
  @@map("wallets")
}

// Short-lived sign-in challenges for the wallet-connect flow (login/signup
// and linking additional wallets). Consumed once, then kept for audit until
// expiry cleanup.
model WalletChallenge {
  id         String    @id @default(uuid())
  address    String
  chain      String
  nonce      String    @unique
  message    String
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([address, chain])
  @@map("wallet_challenges")
}

model Category {
  id                Int               @id @default(autoincrement())
  name              String
  slug              String            @unique
  listingCategories ListingCategory[]

  @@map("categories")
}

model Collection {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  img      String?
  listings Listing[]

  @@map("collections")
}

model Tag {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  listingTags ListingTag[]

  @@map("tags")
}

model License {
  id                Int       @id @default(autoincrement())
  name              String
  rightsDescription String    @map("rights_description")
  allowsResale      Boolean   @map("allows_resale")
  listings          Listing[]
  nfts              Nft[]

  @@map("licenses")
}

// One asset = one XLS-20 NFToken minted on the XRP Ledger by its creator.
// Written only after the on-chain NFTokenMint is verified (see tokenize
// service): nftokenId + issuer are re-derived from the validated tx, never
// trusted from the client.
model Nft {
  id             String   @id @default(uuid())
  listingId      String   @unique @map("listing_id")
  licenseId      Int?     @map("license_id")
  nftokenId      String   @unique @map("nftoken_id")
  issuer         String
  taxon          Int      @default(0)
  uri            String?
  mintTxHash     String   @unique @map("mint_tx_hash")
  currentOwnerId String   @map("current_owner_id")
  mintedAt       DateTime @default(now()) @map("minted_at")

  listing      Listing  @relation(fields: [listingId], references: [id])
  license      License? @relation(fields: [licenseId], references: [id])
  currentOwner User     @relation("NftOwner", fields: [currentOwnerId], references: [id])
  resales      Resale[]

  // "NFTs owned by a user" lookup (users.service.exportMyData).
  @@index([currentOwnerId])
  @@map("nfts")
}

model Listing {
  id                String    @id @default(uuid())
  sellerId          String    @map("seller_id")
  collectionId      Int?      @map("collection_id")
  licenseId         Int?      @map("license_id")
  slug              String?   @unique
  title             String
  shortDescription  String?   @map("short_description")
  description       String?
  fileIpfsCid       String?   @map("file_ipfs_cid")
  thumbnailCid      String?   @map("thumbnail_cid")
  isFree            Boolean   @default(false) @map("is_free")
  price             Decimal?
  currency          String?
  distributionMode  String    @default("unlimited") @map("distribution_mode")
  maxDownloads      Int?      @map("max_downloads")
  royaltyPercentage Decimal?  @map("royalty_percentage")
  status            String    @default("Draft")
  viewsCount        Int       @default(0) @map("views_count")
  salesCount        Int       @default(0) @map("sales_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  deletedAt         DateTime? @map("deleted_at")

  seller            User              @relation(fields: [sellerId], references: [id])
  collection        Collection?       @relation(fields: [collectionId], references: [id])
  license           License?          @relation(fields: [licenseId], references: [id])
  listingCategories ListingCategory[]
  listingTags       ListingTag[]
  purchases         Purchase[]
  downloads         Download[]
  reviews           Review[]
  favorites         Favorite[]
  nft               Nft?

  // Creator dashboard + public profile: a seller's listings ordered by
  // recency (assets.service.listMyListings, users.service.listUserAssets).
  @@index([sellerId, createdAt])
  // Published catalogue with the default createdAt sort
  // (assets.service.listAssets, admin.service.listAllAssets).
  @@index([status, createdAt])
  // Trigram indexes for ILIKE '%q%' search on the catalogue
  // (search.service.searchAssets, assets.service.buildWhere).
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("listings")
}

model ListingCategory {
  listingId  String @map("listing_id")
  categoryId Int    @map("category_id")

  listing  Listing  @relation(fields: [listingId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([listingId, categoryId])
  // The composite PK only serves listing_id-prefixed lookups; browsing a
  // category (categories.service.findCategoryListings) filters by category_id
  // alone.
  @@index([categoryId])
  @@map("listing_categories")
}

model ListingTag {
  listingId String @map("listing_id")
  tagId     Int    @map("tag_id")

  listing Listing @relation(fields: [listingId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([listingId, tagId])
  // Same asymmetry as listing_categories: the tag filter on the catalogue
  // (assets.service.buildWhere) resolves listings from tag_id alone.
  @@index([tagId])
  @@map("listing_tags")
}

model Download {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  listingId    String   @map("listing_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  // Download history, newest first (downloads.service.listMyDownloads).
  @@index([userId, downloadedAt])
  // Distinct-downloaders cap check and per-asset stats
  // (downloads.service.requestDownload, creator.service.getCreatorAssetStats).
  @@index([listingId])
  @@map("downloads")
}

model Purchase {
  id          String   @id @default(uuid())
  buyerId     String   @map("buyer_id")
  listingId   String   @map("listing_id")
  txHash      String   @unique @map("tx_hash")
  amountPaid  Decimal  @map("amount_paid")
  status      String   @default("Pending")
  // Payment target snapshotted at order creation: the seller's wallet address
  // and a per-order XRPL DestinationTag. Confirmation requires the on-chain tx
  // to carry this exact tag, which binds a payment to this specific order
  // (prevents replaying any other payment to the same seller).
  paymentAddress String? @map("payment_address")
  paymentTag     Int?    @map("payment_tag")
  purchasedAt DateTime @default(now()) @map("purchased_at")

  buyer   User    @relation(fields: [buyerId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  // Buyer's order history, newest first (orders.service.listOrders).
  @@index([buyerId, purchasedAt])
  // Confirmed-sales lookups per listing: stock cap, entitlement, revenue
  // aggregates (orders/downloads/reviews/creator/stats services).
  @@index([listingId, status])
  @@map("purchases")
}

model Review {
  id         String   @id @default(uuid())
  listingId  String   @map("listing_id")
  reviewerId String   @map("reviewer_id")
  rating     Int
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  listing  Listing @relation(fields: [listingId], references: [id])
  reviewer User    @relation(fields: [reviewerId], references: [id])

  // Reviews of an asset with the default createdAt sort
  // (reviews.service.listAssetReviews) + rating aggregates per listing.
  @@index([listingId, createdAt])
  // Reviews written by a user (users.service.listUserReviews).
  @@index([reviewerId])
  @@map("reviews")
}

model Favorite {
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  addedAt   DateTime @default(now()) @map("added_at")

  user    User    @relation(fields: [userId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])

  @@id([userId, listingId])
  // The composite PK covers user_id lookups (listMyFavorites) but not the
  // per-asset favorites count (creator.service.getCreatorAssetStats).
  @@index([listingId])
  @@map("favorites")
}


model Resale {
  id                String   @id @default(uuid())
  nftId             String   @map("nft_id")
  sellerId          String   @map("seller_id")
  price             Decimal
  currency          String
  status            String   @default("Active")
  txHash            String?  @unique @map("tx_hash")
  royaltyPercentage Decimal? @map("royalty_percentage")
  createdAt         DateTime @default(now()) @map("created_at")

  nft    Nft  @relation(fields: [nftId], references: [id])
  seller User @relation(fields: [sellerId], references: [id])

  @@map("resales")
}

model LogCategory {
  code        String    @id
  description String?
  logTypes    LogType[]

  @@map("log_categories")
}

model LogType {
  code         String   @id
  categoryCode String   @map("category_code")
  description  String?
  rawLogs      RawLog[]

  category LogCategory @relation(fields: [categoryCode], references: [code])

  @@map("log_types")
}

model RawLog {
  id          String   @id @default(uuid())
  logTypeCode String   @map("log_type_code")
  actorId     String?  @map("actor_id")
  targetType  String?  @map("target_type")
  targetId    String?  @map("target_id")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  logType LogType @relation(fields: [logTypeCode], references: [code])

  @@map("raw_logs")
}

model AggregatedStat {
  id            String   @id @default(uuid())
  targetType    String   @map("target_type")
  targetId      String?  @map("target_id")
  metricName    String   @map("metric_name")
  metricValue   Decimal  @map("metric_value")
  period        String
  referenceDate DateTime @map("reference_date") @db.Date
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("aggregated_stats")
}
