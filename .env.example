# =============================================================================
# Actify — production environment (docker-compose.prod.yml)
# Copy to .env, fill in values, NEVER commit .env
# =============================================================================
# Only these three are needed: docker-compose builds DATABASE_URL from them
# and injects it into the api and migrate services.
#
# ⚠️  POSTGRES_PASSWORD must NOT contain characters that break a URL
#     (@ : / ? # [ ] !). Either pick an alphanumeric password, or URL-encode
#     it — otherwise the derived DATABASE_URL is malformed.

POSTGRES_USER=actify
POSTGRES_PASSWORD=changeme
POSTGRES_DB=actify
