# =============================================================================
# Actify — production environment (docker-compose.prod.yml)
# Copy to .env, fill in values, NEVER commit .env
# =============================================================================
# Only these three are needed: docker-compose builds DATABASE_URL from them
# and injects it into the api and migrate services.
#
# ⚠️  POSTGRES_PASSWORD must NOT contain characters that break a URL
#     (@ : / ? # [ ] !). Either pick an alphanumeric password, or URL-encode
#     it — otherwise the derived DATABASE_URL is malformed.

POSTGRES_USER=actify
POSTGRES_PASSWORD=changeme
POSTGRES_DB=actify

# Signs/verifies API access tokens. Generate a real secret for production,
# e.g. `openssl rand -hex 32`.
JWT_SECRET=changeme

# XRPL JSON-RPC endpoint used to verify order payments and NFT mints on-chain.
# Optional — defaults to the public Testnet endpoint if unset.
XRPL_RPC_URL=https://s.altnet.rippletest.net:51234/

# On-chain verification polls `tx` until the transaction is validated by
# consensus (wallets return the hash at submission, ~3-5s earlier).
# Optional — defaults: 8 attempts spaced 1500ms apart (~10.5s worst case).
XRPL_TX_POLL_ATTEMPTS=8
XRPL_TX_POLL_INTERVAL_MS=1500

# Bootstrap admin: the XRPL wallet address that is auto-promoted to the admin
# role on login. REQUIRED to have any admin in production — leave empty to
# disable admin bootstrap entirely.
ADMIN_WALLET_ADDRESS=

# ─── Umami analytics (services umami + umami_db) ─────────────────────────────
# Secret used by Umami to sign its sessions. Generate a real one:
# `openssl rand -hex 32`.
UMAMI_APP_SECRET=changeme

# Password of the dedicated Umami database. Same URL-safety constraint as
# POSTGRES_PASSWORD above (it is embedded in a DATABASE_URL).
UMAMI_DB_PASSWORD=changeme

# Public origin where the VPS reverse-proxy exposes the umami service,
# e.g. https://umami.actify.yohan-georgelin.fr — the subdomain and its vhost
# must be configured in the reverse-proxy on the VPS (outside this repo).
# Empty = analytics disabled in the frontend.
NUXT_PUBLIC_UMAMI_HOST=

# Website ID created in the Umami admin (Settings → Websites) after the first
# login (default credentials admin/umami — change them immediately).
# Empty = analytics disabled in the frontend.
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
