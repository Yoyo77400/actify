# Dev server (nuxt dev)
PORT=8080
NODE_ENV=development

# Public API base used by the client.
# Dev (no proxy): call the API directly.
NUXT_PUBLIC_API_BASE=http://localhost:3000/api/v1
# Prod: set to /api/v1 — the Nitro server proxies it to the internal api
# service (see nuxt.config.ts $production). The api is never exposed directly.

# Production SSR server (Nitro) — set by the Dockerfile, listed here for reference
# NITRO_HOST=0.0.0.0
# NITRO_PORT=3000

# Self-hosted Umami analytics — both empty by default = tracker disabled.
# Even when configured, the script is only injected after the user accepts the
# cookie-consent banner (see app/plugins/umami.client.ts).
# Host: public origin of the Umami instance (e.g. https://umami.example.com).
# Website ID: created in the Umami admin (Settings → Websites).
NUXT_PUBLIC_UMAMI_HOST=
NUXT_PUBLIC_UMAMI_WEBSITE_ID=